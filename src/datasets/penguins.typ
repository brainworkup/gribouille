///     y: "body-mass",
///     colour: "species",
///     shape: "species",
///   ),
///   layers: (
///     geom-point(size: 2pt, stroke: 0.5pt, alpha: 0.5),
///     geom-smooth(method: "lm", se: true, alpha: 0.2),
///   ),
///   scales: (
///     scale-x-continuous(),
///     scale-y-continuous(),
